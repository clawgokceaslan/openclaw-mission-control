{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2021"
    ],
    "jsx": "react-jsx",
    "types": [
      "node",
      "vite/client"
    ]
  },
  "include": [
    "src/renderer/**/*.tsx",
    "src/renderer/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "out/**",
    "dist/**",
    "node_modules/**"
  ]
}
