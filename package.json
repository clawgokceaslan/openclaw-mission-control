{
  "name": "openmissioncontrol",
  "version": "0.1.0",
  "description": "OpenMissionControl desktop app",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "npm run rebuild:native",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cloc": "cloc . --include-lang=\"TypeScript,JavaScript,TSX,JSX\" --exclude-dir=node_modules,dist,out,build,.next,coverage,.turbo,.git --fullpath --not-match-f='(^|/)(package-lock\\.json|pnpm-lock\\.yaml|yarn\\.lock)$' --report-file=cloc_report.txt",
    "lint": "echo \"skip\""
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "ajv": "^8.18.0",
    "better-sqlite3": "^11.9.1",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.44.2",
    "marked": "^15.0.12",
    "moment": "^2.30.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "react-select": "^5.10.2",
    "reactflow": "^11.11.4",
    "sass": "^1.99.0",
    "sqlite3": "5.1.7",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.15.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/sqlite3": "^5.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.1.0",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
